{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.instantmed.com.au"
        }
      ],
      "destination": "https://instantmed.com.au/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/abandoned-checkouts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/recover-partial-intakes",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/cleanup-intake-drafts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/dlq-monitor",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/retry-drafts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/stale-queue",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/emergency-flags",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cleanup-orphaned-storage",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/release-stale-claims",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/email-dispatcher",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/telegram-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/business-alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ahpra-reverification",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/daily-reconciliation",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/posthog-reconciliation",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/qa-sampling",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/retry-auto-approval",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/review-request",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/outbox-archival",
      "schedule": "0 4 * * *"
    }
  ]
}
