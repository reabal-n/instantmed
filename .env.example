# ============================================
# InstantMed Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3060

# --- Stripe Payments ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (Required in production)
STRIPE_PRICE_MEDCERT=price_...
STRIPE_PRICE_MEDCERT_2DAY=price_...
STRIPE_PRICE_MEDCERT_3DAY=price_...
STRIPE_PRICE_REPEAT_SCRIPT=price_...
STRIPE_PRICE_CONSULT=price_...
# Consult subtypes — REQUIRED in production.
# lib/stripe/price-mapping.ts throws at checkout if any of these are missing
# when NODE_ENV=production. Mischarging a customer is worse than a 500.
STRIPE_PRICE_CONSULT_ED=price_...
STRIPE_PRICE_CONSULT_HAIR_LOSS=price_...
STRIPE_PRICE_CONSULT_WOMENS_HEALTH=price_...
STRIPE_PRICE_CONSULT_WEIGHT_LOSS=price_...
# Add-ons
STRIPE_PRICE_PRIORITY_FEE=price_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="InstantMed <noreply@instantmed.com.au>"
RESEND_WEBHOOK_SECRET=whsec_...
SUPABASE_AUTH_WEBHOOK_HOOK_SECRET=  # Generate in Supabase Auth > Hooks > Send Email

# --- Security (Required in production) ---
ENCRYPTION_KEY=  # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PHI_ENCRYPTION_ENABLED=true
PHI_MASTER_KEY=  # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTERNAL_API_SECRET=  # Generate: openssl rand -hex 32

# --- Rate Limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- AI (Claude + Gemini + OpenAI review tooling) ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-proj-...
OPENAI_REVIEW_MODEL=gpt-5.5-pro
VERCEL_AI_GATEWAY_API_KEY=...

# --- Monitoring (Sentry) ---
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...  # Required in CI for source map upload
SENTRY_ORG=reys-projects
SENTRY_PROJECT=instantmed

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cron Authentication ---
CRON_SECRET=  # Generate: openssl rand -hex 32

# --- Search Indexing ---
# Optional. If set, this must match the public /<key>.txt verification file.
INDEXNOW_KEY=b4d7f2a1e9c34568af12de89c7654321
INDEXNOW_SECRET=  # Generate: openssl rand -hex 32

# --- Google ---
GOOGLE_PLACES_API_KEY=...
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# --- Google Ads API / Server-Side Purchase Conversion ---
GOOGLE_ADS_CUSTOMER_ID=9205010513
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_REFRESH_TOKEN=...
GOOGLE_ADS_LOGIN_CUSTOMER_ID=...
GOOGLE_ADS_QUOTA_PROJECT_ID=...
# Must be an offline click-import conversion action with type UPLOAD_CLICKS.
# Do not point this at the browser website purchase/tag conversion action.
GOOGLE_ADS_CONVERSION_ACTION_PURCHASE=7530736987
GOOGLE_ADS_API_VERSION=v24
# Enhanced conversions: the server upload attaches SHA-256 hashed customer
# email + phone (resolved from the patient profile) to each conversion for
# higher match rates. Covers both the live webhook and the cron-backfill path.
# Set to "true" to fall back to gclid-only matching (no user data sent).
# Requires enabling Enhanced conversions + accepting the customer-data terms in
# the Google Ads UI (Goals > Conversions > Settings, method = Google Ads API).
GOOGLE_ADS_ENHANCED_CONVERSIONS_DISABLED=false

# --- Address Search ---
# Prefer server-side ADDRESSFINDER_KEY. Existing deployments may still use
# NEXT_PUBLIC_ADDRESSFINDER_KEY; the server route accepts both names.
# Addressfinder is primary for AU address search; Google Places is fallback.
ADDRESSFINDER_KEY=...
ADDRESSFINDER_SECRET=...

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
TELEGRAM_WEBHOOK_SECRET=...
# Aggregate unread-count alert bridge only. Never forwards Gmail content.
TELEGRAM_SUPPORT_INBOX_ALERTS_ENABLED=0

# --- Admin ---
ADMIN_EMAILS=admin@instantmed.com.au  # Comma-separated

# --- Site URL (SEO fallback) ---
NEXT_PUBLIC_SITE_URL=https://instantmed.com.au

# --- Parchment ePrescribing ---
PARCHMENT_API_URL=https://api.parchmenthealth.io/external
PARCHMENT_PARTNER_ID=instantmed
PARCHMENT_PARTNER_SECRET=
PARCHMENT_ORGANIZATION_ID=  # From Parchment portal Settings → Organisation
PARCHMENT_ORGANIZATION_SECRET=  # From Parchment portal Settings → Organisation
PARCHMENT_WEBHOOK_SECRET=  # From Parchment portal Settings → Webhooks
PARCHMENT_DEFAULT_USER_ID=  # Any Parchment user ID for org-level API calls (e.g. list users)
PARCHMENT_SMOKE_USER_ID=  # Optional; falls back to PARCHMENT_DEFAULT_USER_ID for production smoke
# Optional host override. Default allows localhost, Vercel previews, instantmed.com.au, and www.instantmed.com.au.
NEXT_PUBLIC_PARCHMENT_IFRAME_ALLOWED_HOSTS=

# --- Node ---
NODE_ENV=development
