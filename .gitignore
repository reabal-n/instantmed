# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
e2e/.e2e-run-id

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Lighthouse / audit reports
lighthouse-report.json
lighthouse-report*.json
.env*.local

# Sentry Config File
.env.sentry-build-plugin

# clerk configuration (can include secrets)
/.clerk/

*storybook.log
storybook-static

# Sanity
.sanity/

# IDE config (contains local machine paths and secrets)
.windsurf/
.cursor/

# Playwright MCP logs
.playwright-mcp/

# Audit/debug screenshots
*.png
!public/branding/*.png
!public/logos/*.png
!public/images/**/*.png
!app/icon.png
!app/apple-icon.png

node_modules
node_modules 2
.env
# Worktrees
.worktrees/
DAILY_AUDIT_PROMPT.md

# Claude Code session state (scheduled_tasks.lock etc)
.claude/

# MCP config (contains absolute paths)
.mcp.json

# Tool server dependencies
tools/*/node_modules
