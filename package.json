{
  "name": "instantmed",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "PORT=3060 next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "build:release": "bash scripts/build-release.sh",
    "check:node": "bash scripts/check-node-runtime.sh",
    "check:cron-routes": "node scripts/check-vercel-cron-routes.mjs",
    "check:integrations": "tsx scripts/check-integrations.ts",
    "release:check": "pnpm check:node && bash scripts/check-stack-pins.sh && bash scripts/check-route-conflicts.sh && pnpm check:cron-routes && CHECK_INTEGRATIONS_STRICT=1 pnpm check:integrations && bash scripts/check-orphaned-files.sh && pnpm dedupe --check && pnpm audit --audit-level=high && pnpm lint && pnpm typecheck && pnpm test run && pnpm build:release && bash scripts/check-bundle-size.sh",
    "check:staff-roles": "tsx scripts/check-staff-role-readiness.ts",
    "fix:staff-roles": "tsx scripts/fix-staff-admin-roles.ts",
    "check:sentry": "tsx scripts/check-sentry-access.ts",
    "doc:audit": "bash scripts/doc-audit.sh",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null || true",
    "ci": "pnpm install --frozen-lockfile && pnpm lint && pnpm typecheck && pnpm test run && pnpm build",
    "blog:images": "node scripts/update-blog-images.mjs",
    "blog:generate-visual-images": "tsx scripts/generate-blog-visual-images.ts",
    "blog:apply-visual-assets": "tsx scripts/apply-blog-visual-assets.ts",
    "content:audit": "node scripts/audit-health-guides.mjs",
    "content:audit:images": "node scripts/audit-health-guides.mjs --fail-on-image",
    "content:audit:strict": "node scripts/audit-health-guides.mjs --fail-on=P1",
    "review": "tsx --env-file=.env.local scripts/video-review/index.ts",
    "audit:conversion": "tsx --env-file=.env.local scripts/conversion-funnel-audit.ts",
    "review:reindex": "tsx scripts/video-review/index-update.ts",
    "review:doctor": "tsx --env-file=.env.local scripts/video-review/doctor.ts",
    "smoke:backend": "npx tsx scripts/smoke-backend.ts",
    "smoke:prod-dashboard": "node scripts/smoke-dashboard-production.mjs",
    "smoke:parchment": "npx tsx scripts/parchment-smoke.ts",
    "db:lint:linked": "supabase db lint --linked --schema public,extensions --fail-on error",
    "db:check-migrations": "node scripts/check-supabase-migration-history.mjs",
    "check:rls": "npx tsx scripts/rls-check.ts",
    "import:artg": "npx tsx scripts/import_artg.ts",
    "encrypt:backfill": "npx tsx scripts/encrypt-phi-backfill.ts",
    "encrypt:backfill:dry": "npx tsx scripts/encrypt-phi-backfill.ts --dry",
    "e2e": "env -u NO_COLOR PLAYWRIGHT=1 playwright test",
    "e2e:ui": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --ui",
    "e2e:headed": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --headed",
    "e2e:debug": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --debug",
    "e2e:chromium": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --project=chromium",
    "e2e:seed": "pnpm tsx scripts/e2e/seed.ts",
    "e2e:teardown": "pnpm tsx scripts/e2e/teardown.ts",
    "e2e:full": "pnpm e2e:teardown || true && env -u NO_COLOR PLAYWRIGHT=1 playwright test && pnpm e2e:teardown || true",
    "e2e:smoke": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --project=chromium e2e/portals.smoke.spec.ts e2e/rbac.spec.ts e2e/admin.ops-index.spec.ts e2e/admin.clinic.spec.ts e2e/marketing-dashboard-nav.spec.ts e2e/medcert.approval.spec.ts e2e/doctor.queue.spec.ts e2e/doctor.patients.spec.ts",
    "e2e:functional": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --project=chromium e2e/operator.journey.spec.ts e2e/admin.ops-index.spec.ts e2e/medcert.approval.spec.ts e2e/doctor.queue.spec.ts e2e/admin.clinic.spec.ts",
    "e2e:a11y": "env -u NO_COLOR PLAYWRIGHT=1 playwright test --project=chromium e2e/accessibility.spec.ts",
    "e2e:prod-synthetic": "env -u NO_COLOR E2E_BASE_URL=https://instantmed.com.au playwright test --config=playwright.preview.config.ts --project=chromium e2e/prod-request-flow-synthetic.spec.ts",
    "medcert:readiness": "bash scripts/check-medcert-readiness.sh",
    "medcert:readiness:e2e": "MEDCERT_READINESS_STATIC=0 bash scripts/check-medcert-readiness.sh",
    "smoke:stripe": "npx tsx scripts/stripe-smoke-test.ts",
    "keys:rotate": "npx tsx scripts/rotate-keys.ts",
    "test:templates": "npx tsx scripts/test-all-templates.ts",
    "seo:generate": "npx tsx scripts/seo-generator.ts",
    "seo:gsc-index-audit": "node tools/gsc-mcp-server/gsc-index-audit.mjs",
    "seo:semrush-pulse": "node tools/semrush/semrush-pulse.mjs",
    "seo:submit-indexing": "node tools/gsc-mcp-server/gsc-submit-indexing.mjs",
    "seo:authority-pulse": "node tools/gsc-mcp-server/authority-resource-pulse.mjs",
    "seo:commercial-pulse": "node tools/gsc-mcp-server/commercial-intent-pulse.mjs",
    "seo:commercial-inspect": "node tools/gsc-mcp-server/commercial-intent-inspect.mjs",
    "seo:generate-commercial-visuals": "tsx scripts/generate-commercial-seo-visual-images.ts",
    "authority:generate-visuals": "tsx scripts/generate-authority-resource-visuals.ts",
    "verify:tokens": "bash scripts/verify-tokens.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@number-flow/react": "^0.5.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "ai": "^6.0.191",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "11.18.2",
    "gray-matter": "4.0.3",
    "lucide-react": "^0.559.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.364.6",
    "posthog-node": "^5.28.11",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "18.3.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.2",
    "@google/genai": "^2.6.0",
    "@next/bundle-analyzer": "15.5.18",
    "@next/eslint-plugin-next": "15.5.18",
    "@playwright/test": "1.60.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "import-in-the-middle": "^2.0.6",
    "playwright": "1.60.0",
    "require-in-the-middle": "^8.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.23.0",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "pnpm": {
    "overrides": {
      "next": "15.5.18",
      "@next/bundle-analyzer": "15.5.18",
      "@next/eslint-plugin-next": "15.5.18",
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1",
      "framer-motion": "11.18.2",
      "tailwindcss": "4.2.2",
      "@tailwindcss/postcss": "4.2.2",
      "postcss": "8.5.10",
      "protobufjs": "^7.5.6",
      "playwright-core": "1.60.0",
      "minimatch@10>brace-expansion": "^5.0.6",
      "ws": "^8.20.1",
      "@ungap/structured-clone": "1.3.1",
      "dompurify": "^3.4.0",
      "fast-uri": "3.1.2",
      "@babel/plugin-transform-modules-systemjs": "7.29.4",
      "esbuild": "0.28.1"
    }
  }
}
