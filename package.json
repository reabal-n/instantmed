{
  "name": "instantmed",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "ci": "pnpm install --frozen-lockfile && pnpm lint && pnpm test run && pnpm build",
    "smoke:backend": "npx tsx scripts/smoke-backend.ts",
    "check:rls": "npx tsx scripts/rls-check.ts",
    "import:artg": "npx tsx scripts/import_artg.ts",
    "encrypt:backfill": "npx tsx scripts/encrypt-phi-backfill.ts",
    "encrypt:backfill:dry": "npx tsx scripts/encrypt-phi-backfill.ts --dry",
    "e2e": "PLAYWRIGHT=1 playwright test",
    "e2e:ui": "PLAYWRIGHT=1 playwright test --ui",
    "e2e:headed": "PLAYWRIGHT=1 playwright test --headed",
    "e2e:debug": "PLAYWRIGHT=1 playwright test --debug",
    "e2e:chromium": "PLAYWRIGHT=1 playwright test --project=chromium",
    "e2e:seed": "pnpm tsx scripts/e2e/seed.ts",
    "e2e:teardown": "pnpm tsx scripts/e2e/teardown.ts",
    "e2e:full": "pnpm e2e:teardown || true && PLAYWRIGHT=1 playwright test && pnpm e2e:teardown || true",
    "e2e:smoke": "PLAYWRIGHT=1 playwright test --project=chromium e2e/portals.smoke.spec.ts e2e/rbac.spec.ts e2e/admin.studio.spec.ts e2e/admin.clinic.spec.ts e2e/medcert.approval.spec.ts e2e/doctor.queue.spec.ts e2e/doctor.patients.spec.ts",
    "e2e:functional": "PLAYWRIGHT=1 playwright test --project=chromium e2e/operator.journey.spec.ts e2e/medcert.approval.spec.ts e2e/doctor.queue.spec.ts e2e/admin.studio.spec.ts e2e/admin.clinic.spec.ts",
    "e2e:a11y": "PLAYWRIGHT=1 playwright test --project=chromium e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@clerk/nextjs": "^7.0.8",
    "@number-flow/react": "^0.5.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "ai": "^6.0.145",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.559.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.364.6",
    "posthog-node": "^5.28.11",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "16.2.2",
    "@next/eslint-plugin-next": "16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "import-in-the-middle": "^2.0.6",
    "require-in-the-middle": "^8.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.23.0",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
