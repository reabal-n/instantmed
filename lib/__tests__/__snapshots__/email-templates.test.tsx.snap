exports[`Email Templates > ScriptSentEmail > matches snapshot 1`] = `
"<html lang="en-AU" style="color-scheme:light dark"><head><meta charSet="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><meta name="color-scheme" content="light dark"/><meta name="supported-color-schemes" content="light dark"/><title>InstantMed</title><div><!--[if mso]>
<style>
  body { background-color: #0f0f0f !important; }
