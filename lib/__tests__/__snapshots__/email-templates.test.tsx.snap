exports[`Email Templates > PrescriptionApprovedEmail > matches snapshot 1`] = `
"<html><head><meta charSet="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><link rel="preload" as="image" href="https://instantmed.com.au/branding/logo.png"/><meta name="color-scheme" content="light dark"/><meta name="supported-color-schemes" content="light dark"/><title>InstantMed</title><style>
          body, td, p, h1, h2, h3, a, span, div, li {
