td class="email-footer" style="padding:32px 40px;border-top:1px solid #F5F5F4;background-color:#FAFAF9"><table role="presentation" cellPadding="0" cellSpacing="0" style="width:100%"><tbody><tr><td style="text-align:center"><p style="margin:0 0 16px 0;font-size:12px;color:#78716C;line-height:1.8"><a href="https://instantmed.com.au/privacy" style="color:#78716C;text-decoration:none">Privacy</a><span style="margin:0 8px;color:#E5E5E5">·</span><a href="https://instantmed.com.au/terms" style="color:#78716C;text-decoration:none">Terms</a><span style="margin:0 8px;color:#E5E5E5">·</span><a href="https://instantmed.com.au/contact" style="color:#78716C;text-decoration:none">Contact</a><span style="margin:0 8px;color:#E5E5E5">·</span><a href="https://instantmed.com.au/account?tab=notifications" style="color:#78716C;text-decoration:none">Preferences</a></p><p style="margin:0 0 8px 0;font-size:12px;color:#78716C">Made with care in Australia 🌤️</p><p style="margin:0;font-size:11px;color:#A8A29E;letter-spacing:0.02em">InstantMed Pty Ltd · ABN 64 694 559 334</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></body></html>"
